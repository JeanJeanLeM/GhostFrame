rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fonction helper pour vérifier si un utilisateur est dans une partie
    function isPlayerInGame(gameId, userId) {
      return exists(/databases/$(database)/documents/games/$(gameId)/players/$(userId));
    }
    
    // Fonction helper pour vérifier si un utilisateur est l'hôte d'une partie
    function isGameHost(gameId, userId) {
      return get(/databases/$(database)/documents/games/$(gameId)/players/$(userId)).data.isHost == true;
    }
    
    // Règles pour les parties
    match /games/{gameId} {
      // Lecture : tous les utilisateurs authentifiés peuvent lire les parties publiques
      allow read: if request.auth != null;
      
      // Création : utilisateurs authentifiés uniquement
      allow create: if request.auth != null 
        && request.auth.uid != null
        && request.resource.data.createdBy == request.auth.uid;
      
      // Mise à jour : seulement les joueurs de la partie
      allow update: if request.auth != null 
        && isPlayerInGame(gameId, request.auth.uid)
        && (
          // Les joueurs peuvent mettre à jour leur statut ready
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players']) &&
           request.resource.data.players[request.auth.uid].diff(resource.data.players[request.auth.uid]).affectedKeys().hasOnly(['isReady', 'connected', 'lastSeen']))
          ||
          // L'hôte peut changer le statut de la partie
          (isGameHost(gameId, request.auth.uid) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'currentTurn']))
        );
      
      // Suppression : seulement l'hôte
      allow delete: if request.auth != null 
        && isGameHost(gameId, request.auth.uid);
      
      // Règles pour les sous-collections des joueurs
      match /players/{playerId} {
        // Lecture : tous les joueurs de la partie
        allow read: if request.auth != null 
          && isPlayerInGame(gameId, request.auth.uid);
        
        // Création/Mise à jour : seulement le joueur lui-même ou l'hôte
        allow write: if request.auth != null 
          && (request.auth.uid == playerId || isGameHost(gameId, request.auth.uid));
        
        // Suppression : seulement le joueur lui-même ou l'hôte
        allow delete: if request.auth != null 
          && (request.auth.uid == playerId || isGameHost(gameId, request.auth.uid));
      }
      
      // Règles pour l'état du jeu
      match /state/{document=**} {
        // Lecture : tous les joueurs de la partie
        allow read: if request.auth != null 
          && isPlayerInGame(gameId, request.auth.uid);
        
        // Écriture : tous les joueurs de la partie (pour les mouvements)
        allow write: if request.auth != null 
          && isPlayerInGame(gameId, request.auth.uid);
      }
    }
    
    // Règles pour les statistiques globales (optionnel)
    match /stats/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Les stats sont mises à jour côté serveur uniquement
    }
    
    // Règles par défaut : refuser tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
